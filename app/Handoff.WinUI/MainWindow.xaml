<Window
    x:Class="Handoff.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Handoff">
    <Grid
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        RequestedTheme="Dark">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <TextBlock
                Margin="52,0,160,0"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Handoff"
                TextTrimming="CharacterEllipsis" />
        </Grid>

        <NavigationView
            x:Name="ShellNavigation"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="LeftCompact"
            SelectionFollowsFocus="Disabled">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Icon="Home" IsSelected="True" />
                <NavigationViewItem Content="Team" Icon="People" />
                <NavigationViewItem Content="Activity" Icon="Sync" />
            </NavigationView.MenuItems>

            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Auto">
            <Grid
                x:Name="ContentRoot"
                Padding="28"
                RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid
                    x:Name="HeaderGrid"
                    ColumnSpacing="16"
                    RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="Handoff"
                            Style="{ThemeResource TitleTextBlockStyle}" />
                        <TextBlock
                            Text="Team branch discovery and local context sync"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Button
                        x:Name="DiscoverButton"
                        Grid.Column="1"
                        MinWidth="168"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="DiscoverButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE895;" />
                            <TextBlock Text="Discover" />
                        </StackPanel>
                    </Button>
                </Grid>

                <InfoBar
                    x:Name="StatusInfoBar"
                    Grid.Row="1"
                    Margin="0,20,0,20"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational"
                    Title="Starting"
                    Message="Daemon is starting." />

                <Grid
                    x:Name="MainContentGrid"
                    Grid.Row="2"
                    ColumnSpacing="20"
                    RowSpacing="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" Width="320" />
                        <ColumnDefinition x:Name="DetailsColumn" Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        x:Name="SidebarPanel"
                        Spacing="16">
                        <Border
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="16">
                                <Grid>
                                    <TextBlock
                                        Text="Sync status"
                                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                                    <ProgressRing
                                        x:Name="SyncProgress"
                                        Width="24"
                                        Height="24"
                                        HorizontalAlignment="Right"
                                        IsActive="False" />
                                </Grid>

                                <Grid ColumnSpacing="12" RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="2">
                                        <TextBlock
                                            Text="Branches"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock
                                            x:Name="BranchCountText"
                                            Text="--"
                                            Style="{ThemeResource TitleTextBlockStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            Text="Members"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock
                                            x:Name="MemberCountText"
                                            Text="--"
                                            Style="{ThemeResource TitleTextBlockStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Spacing="2">
                                        <TextBlock
                                            Text="Last sync"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock
                                            x:Name="LastSyncText"
                                            Text="Waiting"
                                            TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            Text="Fetch"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock
                                            x:Name="FetchStatusText"
                                            Text="Unknown"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="Workspace"
                                    Style="{ThemeResource SubtitleTextBlockStyle}" />

                                <StackPanel Spacing="2">
                                    <TextBlock
                                        Text="Self"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock
                                        x:Name="SelfText"
                                        Text="Not loaded"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock
                                        Text="Repository"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock
                                        x:Name="RepoPathText"
                                        Text="Locating repository..."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Grid
                        x:Name="DetailsPanel"
                        Grid.Column="1"
                        RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Text="Discovered team context"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />

                        <Grid
                            x:Name="ContextGrid"
                            Grid.Row="1"
                            ColumnSpacing="16"
                            RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="MembersColumn" Width="260" />
                                <ColumnDefinition x:Name="BranchesColumn" Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                x:Name="MembersPanel"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid Padding="16" RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Team members" FontWeight="SemiBold" />
                                    <ListView
                                        x:Name="MembersList"
                                        Grid.Row="1"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon
                                                        VerticalAlignment="Center"
                                                        FontSize="14"
                                                        Glyph="&#xE77B;" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{Binding}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>

                            <Border
                                x:Name="BranchesPanel"
                                Grid.Column="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid Padding="16" RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Branches" FontWeight="SemiBold" />
                                    <ListView
                                        x:Name="BranchesList"
                                        Grid.Row="1"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon
                                                        VerticalAlignment="Center"
                                                        FontSize="14"
                                                        Glyph="&#xE8F1;" />
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock
                                                            Text="{Binding Title}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            Text="{Binding Subtitle}"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <TextBlock
                    x:Name="StatusText"
                    Visibility="Collapsed" />
            </Grid>
            </ScrollViewer>
        </NavigationView>
    </Grid>
</Window>

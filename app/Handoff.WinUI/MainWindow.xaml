<Window
    x:Class="Handoff.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Handoff">
    <StackPanel Padding="16" Spacing="12">
        <Button x:Name="DiscoverButton"
                Content="Discover Team Members"
                Click="DiscoverButton_Click"/>
        <TextBlock x:Name="StatusText"
                   TextWrapping="Wrap"
                   FontFamily="Consolas"
                   Text="Click the button to run discovery."/>
    </StackPanel>
</Window>

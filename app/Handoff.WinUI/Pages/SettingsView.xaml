<UserControl
    x:Class="Handoff.WinUI.Pages.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid Padding="28" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    Text="Settings"
                    Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock
                    Text="Appearance, identity, and connection"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource BodyTextBlockStyle}" />
            </StackPanel>

            <InfoBar
                x:Name="StatusBar"
                Grid.Row="1"
                IsOpen="False"
                IsClosable="True" />

            <Border
                Grid.Row="2"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <TextBlock Text="Appearance" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Text="Theme is applied and saved immediately."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <RadioButton x:Name="ThemeSystemRadio" Content="System" GroupName="Theme" Checked="OnThemeChanged" />
                        <RadioButton x:Name="ThemeLightRadio" Content="Light" GroupName="Theme" Checked="OnThemeChanged" />
                        <RadioButton x:Name="ThemeDarkRadio" Content="Dark" GroupName="Theme" Checked="OnThemeChanged" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Grid.Row="3"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <TextBlock Text="Identity" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Text="Your normalized member name. Used to filter your own folder out of the team roster."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <TextBox
                        x:Name="SelfBox"
                        PlaceholderText="e.g. tugrap" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="4"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <TextBlock Text="Supabase" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Text="REST URL and publishable key. Changes take effect after restarting the app."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <TextBox
                        x:Name="SupabaseUrlBox"
                        Header="URL"
                        PlaceholderText="https://your-project.supabase.co" />
                    <PasswordBox
                        x:Name="SupabaseKeyBox"
                        Header="Key"
                        PlaceholderText="sb_publishable_..." />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="5"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <TextBlock Text="Workspace" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="14" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Repository" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="RepoText" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Text="Config" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="ConfigText" Grid.Row="1" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2" Text="Log" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="LogText" Grid.Row="2" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel
                Grid.Row="6"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10">
                <Button
                    x:Name="RevertButton"
                    Content="Revert"
                    Click="OnRevertClicked" />
                <Button
                    x:Name="SaveButton"
                    Content="Save"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="OnSaveClicked" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>

<UserControl
    x:Class="Handoff.WinUI.Pages.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid Padding="28" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Padding="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Border
                        Width="64"
                        Height="64"
                        Background="{ThemeResource SystemAccentColor}"
                        CornerRadius="12">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="30"
                            Foreground="White"
                            Glyph="&#xE8AB;" />
                    </Border>

                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <TextBlock
                            Text="Handoff"
                            Style="{ThemeResource TitleLargeTextBlockStyle}" />
                        <TextBlock
                            x:Name="TaglineText"
                            Text="Local-first team context daemon"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,4,0,0">
                            <Border
                                Padding="8,2"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="4">
                                <TextBlock
                                    x:Name="VersionBadge"
                                    Text="v0.0.0"
                                    FontSize="12"
                                    FontFamily="Consolas, Cascadia Mono, monospace" />
                            </Border>
                            <Border
                                Padding="8,2"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="4">
                                <TextBlock
                                    x:Name="CommitBadge"
                                    Text="—"
                                    FontSize="12"
                                    FontFamily="Consolas, Cascadia Mono, monospace" />
                            </Border>
                            <Border
                                Padding="8,2"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="4">
                                <TextBlock
                                    x:Name="ConfigurationBadge"
                                    Text="Debug"
                                    FontSize="12"
                                    FontFamily="Consolas, Cascadia Mono, monospace" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Spacing="14">
                        <TextBlock
                            Text="Build"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <Grid ColumnSpacing="14" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Assembly" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="AssemblyText" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="1" Text="Version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="VersionText" Grid.Row="1" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="2" Text="Commit" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="CommitText" Grid.Row="2" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="3" Text="Built" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="BuiltText" Grid.Row="3" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="4" Text="Configuration" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ConfigurationText" Grid.Row="4" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <StackPanel Spacing="14">
                        <TextBlock
                            Text="Runtime"
                            Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <Grid ColumnSpacing="14" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text=".NET" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DotnetText" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="1" Text="OS" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="OsText" Grid.Row="1" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="2" Text="Architecture" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ArchText" Grid.Row="2" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="3" Text="Process" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ProcessText" Grid.Row="3" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="4" Text="Host" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="HostText" Grid.Row="4" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                Grid.Row="2"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="14">
                    <TextBlock
                        Text="Workspace"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="14" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Repository" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="RepoText" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Text="Config" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="ConfigText" Grid.Row="1" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2" Text="Log" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="LogText" Grid.Row="2" Grid.Column="1" Text="—" FontFamily="Consolas, Cascadia Mono, monospace" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>

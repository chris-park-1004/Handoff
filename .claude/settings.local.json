{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:nyosegawa.com)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "WebFetch(domain:support.claude.com)",
      "WebFetch(domain:vibeusage.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node hook/inject-context.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hook/inject-context.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cat > \".team-context/claude-statusline.json\""
  }
}

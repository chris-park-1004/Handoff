{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node hook/receive-shared-context.js",
            "timeout": 30,
            "statusMessage": "Checking team context"
          },
          {
            "type": "command",
            "command": "node hook/shared-context-summary.js",
            "timeout": 300,
            "statusMessage": "Checking local commit"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hook/receive-shared-context.js",
            "timeout": 30,
            "statusMessage": "Checking team context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hook/shared-context-summary.js",
            "timeout": 300,
            "statusMessage": "Checking local commit"
          }
        ]
      }
    ]
  }
}
